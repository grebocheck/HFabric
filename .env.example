# HFabric system settings only.
# Day-to-day model/runtime/generation settings live in the Settings tab and are
# persisted to data/settings-overrides.json.

HFAB_HOST=127.0.0.1
HFAB_PORT=8260

# Optional. Leave empty/unset for local-only use without API authentication.
# Set this before binding HFAB_HOST to a LAN-visible address.
# HFAB_API_TOKEN=change-me

# Serve the built frontend from FastAPI. Leave false when using the Vite dev server.
HFAB_SERVE_FRONTEND=false

# Optional Vite dev-server bind/port for frontend development.
# HFAB_FRONTEND_HOST=
# HFAB_FRONTEND_PORT=5173
